        "Common Cold": {
            "description": "Common Cold is a viral infection of the upper respiratory tract.",
            "recommendations": [
                "Drink vitamin C rich drinks and take steam inhalation"
            ],
            "precautions": [
                "Avoid cold foods and keep a regular check on your temperature"
            ],
            "symptoms": [
                "sneezing",
                "runny nose",
                "sore throat",
                "cough"
            ]
        },
        "Pneumonia": {
            "description": "Pneumonia is an inflammatory condition affecting the air sacs in the lungs caused by infection.",
            "recommendations": [
                "Seek immediate medical assessment at a hospital",
                "Antibiotics and oxygen may be required"
            ],
            "precautions": [
                "Rest completely and follow up with a doctor immediately",
                "Do not attempt home care"
            ],
            "symptoms": [
                "shortness of breath",
                "high fever",
                "chest pain",
                "rapid breathing",
                "low oxygen"
            ]
        },
        "Gastroenteritis": {
            "description": "Gastroenteritis is an inflammation of the stomach and intestines.",
            "recommendations": [
                "Drink plenty of fluids like ORS (Oral Rehydration Solution) or clear broth"
            ],
            "precautions": [
                "Follow a bland diet of Bananas Rice Applesauce and Toast",
                "Avoid solid food initially"
            ],
            "symptoms": [
                "nausea",
